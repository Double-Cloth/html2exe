{
  "name": "html2exe",
  "version": "1.0.0",
  "description": "图形化 Electron 打包器",
  "main": "main.js",
  "scripts": {
    "prebuild": "node pack-toolchain.js",
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "asar": false,
    "compression": "maximum",
    "npmRebuild": false,
    "afterPack": "./afterPack.js",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json",
      "!**/*.map",
      "!**/__tests__/**",
      "!**/test/**",
      "!**/tests/**",
      "!**/*.md",
      "!**/CHANGELOG*"
    ],
    "extraResources": [
      {
        "from": "vendor/toolchain/node_modules",
        "to": "embedded/toolchain/node_modules"
      }
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  }
}
